# GEWS Aggregator — Environment Variables
# Kopyala: cp .env.example .env

# ── WebSocket ─────────────────────────────────────────────
WS_PORT=8765

# ── Supabase (Cloud veya Self-Hosted) ─────────────────────
SUPABASE_URL=https://your-project.supabase.co
# Server-side yazma için SERVICE_ROLE key (anon key DEĞİL!)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Veri Kaynağı API Anahtarları ──────────────────────────
NASA_FIRMS_KEY=your-nasa-firms-key       # https://firms.modaps.eosdis.nasa.gov/api/
# OPENWEATHER_KEY=your-key               # optional
# GDACS_API_KEY=                         # RSS public, key gerekmez

# ── Bildirim (M7 Dissemination) ───────────────────────────
# SENDGRID_API_KEY=SG.xxx
# SENDGRID_FROM=alerts@yourdomain.org
# WHATSAPP_TOKEN=your-meta-business-token
# WHATSAPP_PHONE_ID=your-phone-number-id
